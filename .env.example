# --- Shopify (filled in automatically by `shopify app dev` / `shopify app deploy`) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=read_orders

# --- Database (Prisma + Postgres) ---
# A hosted Postgres database is required if you deploy to Vercel (or any
# serverless platform) - their filesystems are read-only/ephemeral, so
# SQLite cannot be used there. Free options: Vercel Postgres, Neon,
# Supabase, Railway Postgres.
#
# If you're on Vercel Postgres or Neon, use the POOLED connection string
# (often labeled "Prisma" / "pooled" / has "-pooler" in the host), not the
# direct one - serverless functions open a new DB connection per
# invocation and a non-pooled connection will exhaust your connection
# limit under any real traffic.
DATABASE_URL="postgresql://user:password@host:5432/hyperlocal_mailer?sslmode=require"

# --- SMTP defaults (optional) ---
# These pre-fill the Settings page the FIRST time it loads for a shop, but
# the merchant can change everything (recipient email + SMTP + template)
# from inside Shopify admin afterwards without touching this file again.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
