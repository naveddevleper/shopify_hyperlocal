# --- Shopify (filled in automatically by `shopify app dev` / `shopify app deploy`) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=read_orders

# --- Database (Prisma) ---
# SQLite is fine for a single-store custom app. For production hosting on a
# platform with an ephemeral filesystem (e.g. most PaaS free tiers), point
# this at a persistent Postgres database instead, e.g.:
# DATABASE_URL="postgresql://user:password@host:5432/hyperlocal_mailer"
DATABASE_URL="file:dev.sqlite"

# --- SMTP defaults (optional) ---
# These pre-fill the Settings page the FIRST time it loads for a shop, but
# the merchant can change everything (recipient email + SMTP + template)
# from inside Shopify admin afterwards without touching this file again.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
